{
  "name": "@customerjourney/cj-core",
  "version": "1.13.0",
  "description": "Core components and functions to generate touchpoints components for the BuyerJourneyJS project",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.min.js",
  "exports": {
    ".": {
      "import": "./dist/index.min.js"
    },
    "./src/pageloader.css": "./src/pageloader.css"
  },
  "scripts": {
    "prod": "esbuild src/index.js --bundle --minify --format=esm --jsx=automatic --jsx-import-source=preact --outfile=dist/index.min.js",
    "build": "esbuild src/index.js --bundle --format=esm --jsx=automatic --jsx-import-source=preact --outfile=dist/index.js",
    "pretest": "npm run build",
    "test": "node --test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antoniofregoso/cj-core.git"
  },
  "author": "Antonio Fregoso",
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "esbuild": "^0.19.4",
    "jsdom": "^29.1.1"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "animate.css": "^4.1.1",
    "bulma": "^1.0.0",
    "preact": "^10.29.4"
  },
  "bugs": {
    "url": "https://github.com/antoniofregoso/cj-core/issues"
  },
  "homepage": "https://antoniofregoso.github.io/customerjourney/documentation/core/",
  "keywords": [
    "vanilla-javascripts",
    "components",
    "funnels",
    "touchpoints",
    "landing-pages",
    "buyerjourney",
    "customerjourney"
  ]
}
